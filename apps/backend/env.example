# ── Database ──────────────────────────────────────────────────────
# SQLite (default for local dev):
BACKEND_DATABASE_URL=sqlite:///./parently.db
# Neon Postgres (production — get from https://console.neon.tech):
# BACKEND_DATABASE_URL=postgresql://parently:password@ep-xxx.us-east-2.aws.neon.tech/parently?sslmode=require

# ── JWT Auth ─────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in the frontend .env
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── Gmail ─────────────────────────────────────────────────────────
GMAIL_CLIENT_SECRETS_PATH=./client_secrets.json
GMAIL_TOKEN_PATH=./token.json
GMAIL_QUERY=in:inbox newer_than:7d

# ── Gemini (primary LLM — get from https://aistudio.google.com) ──
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI (fallback LLM for digest + RAG embeddings) ────────────
# Used only if Gemini is unavailable.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Stripe Billing ───────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a $3/month recurring price in Stripe Dashboard → Products
STRIPE_PRICE_ID=price_...
FRONTEND_APP_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Cron ─────────────────────────────────────────────────────────
# Shared secret for Railway cron → /api/internal/run-daily-digests
CRON_SECRET=your-cron-secret-here

# ── Storage ───────────────────────────────────────────────────────
DATA_DIR=./data
PDF_FOLDER=./uploads

# ── Support Email (optional, recommended in production) ──────────
SUPPORT_EMAIL=support@parently-ai.com
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=support@parently-ai.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=support@parently-ai.com
SMTP_FROM_NAME=Parently
SMTP_SECURE=false

# ── RAG ───────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
